{
  "name": "pob-analysis",
  "version": "0.1.0",
  "description": "Path of Building build analysis desktop app",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "electron-vite dev --config electron.vite.config.mjs",
    "build": "electron-vite build --config electron.vite.config.mjs",
    "preview": "electron-vite preview --config electron.vite.config.mjs",
    "package:mac": "npm run build && electron-builder --mac --config electron-builder.config.cjs",
    "package:win": "npm run build && electron-builder --win --config electron-builder.config.cjs",
    "package:linux": "npm run build && electron-builder --linux --config electron-builder.config.cjs",
    "package:all": "npm run build && electron-builder --mac --win --linux --config electron-builder.config.cjs"
  },
  "dependencies": {
    "fast-xml-parser": "^5.5.6",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "vite": "^7.3.1"
  }
}
